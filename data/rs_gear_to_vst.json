{
 "_meta": {
  "description": "Seed catalog: Rocksmith gear type → recommended VST3/AU plugins. Free plugins only. Used by /vst/suggest endpoint and the per-piece VST panel hint.",
  "version": 5,
  "updated": "2026-05-28",
  "notes": "v5: add MeldaProduction Free as a second core install — drops Bertom (MTremolo+MVibrato replace it) and upgrades multi-band EQ from 3 → 6 bands (MEqualizer beats kHs 3-Band for the EQ5/EQ8/StudioEQ family). Melda free covers tremolo/vibrato/flanger/phaser/ring-mod/EQ/comp as PRIMARY. KHS stays primary for chorus/limiter/gate/multi-band-comp/wah-filter (Melda's free bundle has no equivalent — its *MB, Turbo*, Vintage* etc. are paid demo and mute periodically). Marvel GEQ is an OPTIONAL third install for users who want true 16-band EQ on EQ5/EQ8."
 },
 "__free_vst_install_guide": {
  "_note": "Two free installs cover the whole library. Optional third for max EQ fidelity.",
  "essential": [
   {
    "name": "Kilohearts Essentials",
    "covers": "Chorus, Delay, Reverb, Filter/Wah, Limiter, Gate, 3-Band EQ (fallback), Distortion/Drive, Bitcrusher, Pitch Shifter (octavers), Ring Mod (fallback)",
    "url": "https://kilohearts.com/products/essentials",
    "install_notes": "Each module ships as an individual VST3 (kHs Chorus.vst3, kHs Delay.vst3, etc.) in /Library/Audio/Plug-Ins/VST3 on macOS. After install, Settings → Scan plugins."
   },
   {
    "name": "MeldaProduction Free (MFreeFXBundle)",
    "covers": "Tremolo (MTremolo), Vibrato (MVibrato), Flanger (MFlanger), Phaser (MPhaser), Ring Mod (MRingModulator), 6-band EQ (MEqualizer), Compressor (MCompressor)",
    "url": "https://www.meldaproduction.com/MFreeFXBundle",
    "install_notes": "Install the FREE-ONLY bundle, not MCompleteBundle. Premium plugins (anything with *MB / Turbo* / Vintage* / MGuitarArchitect / MLimiterX etc.) run in demo mode with PERIODIC AUDIO MUTING — unusable for song playback. The catalog only ever points to verified-free plugins."
   }
  ],
  "optional_for_eq_fidelity": [
   {
    "name": "Voxengo Marvel GEQ",
    "covers": "Pedal_EQ5 + Pedal_EQ8 + Bass_Pedal_BassEQ8 — 16-band linear-phase graphic EQ. Lossless mapping vs MEqualizer's 6-band (which loses 2 of 8 for EQ8).",
    "url": "https://www.voxengo.com/product/marvelgeq/",
    "install_notes": "Free, no registration. VST3 + AU on macOS/Windows."
   },
   {
    "name": "TDR Nova",
    "covers": "Rack_StudioEQ (4-band parametric, 154 songs in the test library). MEqualizer also fits — Nova is just a cleaner musical match.",
    "url": "https://www.tokyodawn.net/tdr-nova/",
    "install_notes": "Free, no registration. VST3 + AU."
   }
  ]
 },
