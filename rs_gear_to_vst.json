{
  "_meta": {
    "description": "Seed catalog: Rocksmith gear type → recommended VST3/AU plugins. Free plugins only. Used by /vst/suggest endpoint and the per-piece VST panel hint.",
    "version": 3,
    "updated": "2026-05-28",
    "notes": "v3: standardise on Kilohearts Essentials. ONE free installer (https://kilohearts.com/products/essentials) gives you 30+ modular FX plug-ins with consistent param naming — way cleaner than the patchwork of vendor-specific frees. Tremolo is the only category where KHS doesn't ship a dedicated module; we keep Bertom FreeTremolo for that."
  },

  "__free_vst_install_guide": {
    "_note": "Just two installs cover the entire library.",
    "essential": [
      {
        "name": "Kilohearts Essentials",
        "covers": "Chorus, Flanger, Phaser, Delay, Reverb, Filter/Wah, Compressor, Limiter, Gate, EQ, Distortion/Drive, Bitcrusher, Pitch Shifter (octavers!), Ring Mod — every category except Tremolo",
        "url": "https://kilohearts.com/products/essentials",
        "install_notes": "Run the installer once. Each module ships as an individual VST3 (kHs Chorus.vst3, kHs Delay.vst3, etc.) in /Library/Audio/Plug-Ins/VST3 on macOS. After install, run Settings → Scan for plugins."
      },
      {
        "name": "Bertom FreeTremolo",
        "covers": "Tremolo, AmpTrem, MultiTrem, AmpVibe, MultiVibe (KHS has no dedicated tremolo)",
        "url": "https://www.bertomaudio.com/freetremolo.html"
      }
    ]
  },

