      "Rate":  {"param": "Rate",  "scale": 0.01, "_hint": "RS 0-100 → VST 0-1 (TAL Rate maps to ~0.1-10 Hz internally)"},
      "Depth": {"param": "Depth", "scale": 0.01},
      "Mix":   {"param": "Wet",   "scale": 0.01, "_hint": "TAL exposes Wet (not Mix); leaves Dry untouched"}
    }
  },
